  <script src="/auth-listener.js"></script>

  <script>
    var product = null;
    var currentUser = null;
    var qty = 1;
    var maxStock = 99;

    // Estado das variantes selecionadas: { variantIndex: { name, optionName, optionPrice } }
    var selectedVariants = {};

    var formatCurrency = function(v) {
      return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(parseFloat(v) || 0);
    };

    // ── Toast ───────────────────────────────────────────────────────────────
    var toastTimer;
    function showToast(msg, type) {
      var el = document.getElementById('toast');
      el.innerHTML = (type === 'success' ? '✅ ' : '❌ ') + msg;
      el.className = 'show ' + (type || 'success');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function() { el.className = type || 'success'; }, 3000);
    }

    // ── Quantidade ──────────────────────────────────────────────────────────
    function changeQty(delta) {
      qty = Math.max(1, Math.min(maxStock, qty + delta));
      document.getElementById('qty-display').innerText = qty;
    }

    // ── Converter URL YouTube para embed ────────────────────────────────────
    function getYouTubeEmbed(url) {
      if (!url) return null;
      var match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|v\/))([^&?\/]+)/);
      return match ? 'https://www.youtube.com/embed/' + match[1] : null;
    }

    // ── Renderiza imagem principal ──────────────────────────────────────────
    function setMainImage(url) {
      var img = document.getElementById('main-img');
      var placeholder = document.getElementById('main-img-placeholder');
      if (url) {
        img.src = url;
        img.classList.remove('hidden');
        placeholder.classList.add('hidden');
      } else {
        img.classList.add('hidden');
        placeholder.classList.remove('hidden');
      }
    }

    // ════════════════════════════════════════════════════════════
    // ── LÓGICA DE PREÇO POR VARIANTE ─────────────────────────
    // ════════════════════════════════════════════════════════════

    function getBasePrice() {
      if (!product) return 0;
      var hasPromo = product.promotional_price && parseFloat(product.promotional_price) < parseFloat(product.price);
      return parseFloat(hasPromo ? product.promotional_price : product.price) || 0;
    }

    function getEffectivePrice() {
      var keys = Object.keys(selectedVariants);
      for (var k = 0; k < keys.length; k++) {
        var sel = selectedVariants[keys[k]];
        if (sel && sel.optionPrice != null && !isNaN(sel.optionPrice)) {
          return sel.optionPrice;
        }
      }
      return getBasePrice();
    }

    function updatePriceDisplay() {
      var effective = getEffectivePrice();
      var priceEl = document.getElementById('price-main');
      priceEl.classList.remove('price-flash');
      void priceEl.offsetWidth;
      priceEl.classList.add('price-flash');
      priceEl.innerText = formatCurrency(effective);
    }

    function hasAnyPerOptionPricing() {
      if (!product || !product.variants) return false;
      return product.variants.some(function(v) { return v.per_option_price; });
    }

    function selectVariant(btn, variantIndex, optionName, optionPrice) {
      var parent = btn.parentElement;
      parent.querySelectorAll('.variant-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedVariants[variantIndex] = {
        variantName: btn.getAttribute('data-variant-name'),
        optionName: optionName,
        optionPrice: optionPrice
      };
      updatePriceDisplay();
    }

    // ── Renderiza produto ───────────────────────────────────────────────────
    function renderProduct(p) {
      product = p;
      maxStock = p.stock || 99;
      selectedVariants = {};

      document.title = (p.title || 'Produto') + ' | FreoFigures';

      if (p.category) {
        document.getElementById('breadcrumb-cat').innerText = p.category;
        document.getElementById('breadcrumb-sep').style.display = 'inline';
      }
      document.getElementById('breadcrumb-title').innerText = p.title || '';
      document.getElementById('product-category').innerText = p.category || '';

      var tagsEl = document.getElementById('product-tags');
      if (p.tags && p.tags.length > 0) {
        tagsEl.innerHTML = p.tags.map(function(tag) {
          return '<span class="tag-pill">' + tag + '</span>';
        }).join('');
      }

      document.getElementById('product-title').innerText = p.title || '';

      var hasPromo = p.promotional_price && parseFloat(p.promotional_price) < parseFloat(p.price);
      var displayPrice = hasPromo ? p.promotional_price : p.price;
      document.getElementById('price-main').innerText = formatCurrency(displayPrice);

      if (hasPromo) {
        document.getElementById('price-promo').classList.remove('hidden');
        document.getElementById('price-original').innerText = formatCurrency(p.price);
        var pct = Math.round((1 - parseFloat(p.promotional_price) / parseFloat(p.price)) * 100);
        document.getElementById('price-discount-badge').classList.remove('hidden');
        document.getElementById('price-discount-pct').innerText = pct;
      }

      if (hasAnyPerOptionPricing()) {
        document.getElementById('price-variant-notice').classList.remove('hidden');
      }

      var estoqueEl = document.getElementById('estoque-badge');
      var stock = p.stock || 0;
      if (stock <= 0) {
        estoqueEl.className = 'estoque-out inline-flex items-center gap-1.5 font-mono text-xs px-3 py-1.5';
        estoqueEl.innerHTML = '<span style="width:6px;height:6px;border-radius:50%;background:#f87171;display:inline-block;flex-shrink:0"></span> Fora de estoque';
        document.getElementById('btn-cart').disabled = true;
      } else if (stock <= 5) {
        estoqueEl.className = 'estoque-low inline-flex items-center gap-1.5 font-mono text-xs px-3 py-1.5';
        estoqueEl.innerHTML = '<span style="width:6px;height:6px;border-radius:50%;background:#fb923c;display:inline-block;flex-shrink:0"></span> Últimas ' + stock + ' unidades';
        maxStock = stock;
      } else {
        estoqueEl.className = 'estoque-ok inline-flex items-center gap-1.5 font-mono text-xs px-3 py-1.5';
        estoqueEl.innerHTML = '<span style="width:6px;height:6px;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0"></span> Em estoque';
      }

      // ── Monta galeria: vídeo primeiro (se houver), depois imagens ──
      var images = Array.isArray(p.images) ? p.images.filter(Boolean) : [];
      var embedUrl = getYouTubeEmbed(p.video_url);

      // galleryItems: array de { type: 'image'|'youtube'|'video', src }
      galleryItems = [];
      if (embedUrl) {
        galleryItems.push({ type: 'youtube', src: embedUrl });
      } else if (p.video_url) {
        galleryItems.push({ type: 'video', src: p.video_url });
      }
      images.forEach(function(url) {
        galleryItems.push({ type: 'image', src: url });
      });

      galleryIndex = 0;
      renderGalleryItem(0);

      // Thumbnails
      var thumbsGrid = document.getElementById('thumbs-grid');
      if (galleryItems.length > 1) {
        thumbsGrid.innerHTML = galleryItems.map(function(item, i) {
          var inner = '';
          if (item.type === 'image') {
            inner = '<img src="' + item.src + '" class="w-full h-full object-cover">';
          } else {
            inner = '<div class="w-full h-full flex items-center justify-center bg-black">'
              + '<svg class="w-6 h-6 text-freo-orange" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>'
              + '</div>';
          }
          return '<div class="thumb w-20 h-20 bg-freo-dark border border-white/[0.06] rounded overflow-hidden' + (i === 0 ? ' active' : '') + '" onclick="selectGalleryItem(' + i + ')">'
            + inner + '</div>';
        }).join('');
      } else {
        thumbsGrid.innerHTML = '';
      }

      var descEl = document.getElementById('product-description');
      if (p.description) {
        descEl.innerHTML = p.description.split('\n').map(function(line) {
          return line.trim() ? '<p>' + line + '</p>' : '';
        }).join('');
      } else {
        descEl.innerHTML = '<p class="text-white/30 italic">Sem descrição disponível.</p>';
      }

      var variants = Array.isArray(p.variants) ? p.variants : [];
      var validVariants = variants.filter(function(v) { return v.name && v.options && v.options.length > 0; });

      if (validVariants.length > 0) {
        var varSection = document.getElementById('variants-section');
        varSection.classList.remove('hidden');

        varSection.innerHTML = validVariants.map(function(v, vi) {
          var isPriced = !!v.per_option_price;

          var optionsHTML = v.options.map(function(opt) {
            var optName  = typeof opt === 'object' ? (opt.name  || '') : String(opt || '');
            var optPrice = (typeof opt === 'object' && opt.price != null && !isNaN(opt.price))
                            ? parseFloat(opt.price)
                            : null;

            var dataPrice = optPrice != null ? optPrice : '';
            var priceLabel = '';
            if (isPriced && optPrice != null) {
              priceLabel = '<span class="variant-price-tag">' + formatCurrency(optPrice) + '</span>';
            } else if (isPriced) {
              priceLabel = '<span class="variant-price-tag" style="color:rgba(255,255,255,0.2)">preço padrão</span>';
            }

            return '<button class="variant-btn" '
              + 'data-variant-index="' + vi + '" '
              + 'data-variant-name="' + v.name.replace(/"/g, '&quot;') + '" '
              + 'data-option-name="' + optName.replace(/"/g, '&quot;') + '" '
              + 'data-option-price="' + dataPrice + '" '
              + 'onclick="selectVariant(this, ' + vi + ', \'' + optName.replace(/'/g, "\\'") + '\', ' + (optPrice != null ? optPrice : 'null') + ')">'
              + optName
              + priceLabel
              + '</button>';
          }).join('');

          return '<div>'
            + '<label class="font-mono text-xs text-white/40 uppercase tracking-widest mb-2 block">' + v.name + '</label>'
            + '<div class="flex gap-2 flex-wrap">' + optionsHTML + '</div>'
            + '</div>';
        }).join('');

        var varDetail = document.getElementById('variants-detail');
        var varDetailContent = document.getElementById('variants-detail-content');
        varDetail.classList.remove('hidden');
        varDetailContent.innerHTML = validVariants.map(function(v) {
          var isPriced = !!v.per_option_price;
          var optsText = v.options.map(function(opt) {
            var name  = typeof opt === 'object' ? (opt.name || '') : String(opt || '');
            var price = (typeof opt === 'object' && opt.price != null) ? ' (' + formatCurrency(opt.price) + ')' : '';
            return name + (isPriced ? price : '');
          }).join(', ');

          return '<div class="flex gap-3">'
            + '<span class="font-mono text-xs text-white/40 uppercase tracking-widest w-20 flex-shrink-0 pt-0.5">' + v.name + ':</span>'
            + '<span class="font-body text-sm text-freo-light/60">' + optsText + '</span>'
            + '</div>';
        }).join('');
      }

      document.getElementById('page-loading').classList.add('hidden');
      document.getElementById('page-content').classList.remove('hidden');
    }
    var galleryItems = [];
    var galleryIndex = 0;

    function renderGalleryItem(index) {
      var wrap = document.querySelector('.img-zoom-wrap');
      var item = galleryItems[index];
      if (!item) return;

      if (item.type === 'image') {
        wrap.style.cursor = 'zoom-in';
        wrap.innerHTML = '<img id="main-img" src="' + item.src + '" alt="Produto" class="w-full h-full object-cover" style="opacity:1">';
      } else if (item.type === 'youtube') {
        wrap.style.cursor = 'default';
        wrap.innerHTML = '<iframe src="' + item.src + '?autoplay=0" class="w-full h-full" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen style="aspect-ratio:1;min-height:100%"></iframe>';
      } else if (item.type === 'video') {
        wrap.style.cursor = 'default';
        wrap.innerHTML = '<video src="' + item.src + '" controls muted playsinline class="w-full h-full" style="object-fit:contain;background:#000"></video>';
      }

      document.querySelectorAll('.thumb').forEach(function(t, i) {
        t.classList.toggle('active', i === index);
      });
      galleryIndex = index;
    }

    function selectGalleryItem(index) {
      renderGalleryItem(index);
    }

    function navigateGallery(dir) {
      if (galleryItems.length === 0) return;
      var next = (galleryIndex + dir + galleryItems.length) % galleryItems.length;
      renderGalleryItem(next);
    }
    

    // ── Adicionar ao carrinho ───────────────────────────────────────────────
    async function addToCart() {
      if (!product) return;

      var session = await window.supabaseClient.auth.getSession();
      var s = session.data && session.data.session;

      if (!s) {
        // Salva a intenção no localStorage antes de redirecionar para o login
        localStorage.setItem('freo_pending_cart', JSON.stringify({
          id: product.id,
          title: product.title,
          price: getEffectivePrice(),
          image: (product.images && product.images.length > 0) ? product.images[0] : '',
          quantity: qty,
          variants: selectedVariants
        }));
        window.location.href = '/login.html';
        return;
      }

      var btn = document.getElementById('btn-cart');
      btn.disabled = true;
      btn.innerHTML = '<div class="w-5 h-5 border-2 border-freo-black/30 border-t-freo-black rounded-full animate-spin"></div> Adicionando...';

      try {
        var priceNum = getEffectivePrice();
        var thumb = (product.images && product.images.length > 0) ? product.images[0] : null;

        var variantKeys = Object.keys(selectedVariants);
        var variantStr = variantKeys.length > 0
          ? variantKeys.map(function(k) {
              var sel = selectedVariants[k];
              return sel.variantName + ': ' + sel.optionName;
            }).join(' | ')
          : null;

        var query = window.supabaseClient
          .from('cart_items')
          .select('id, quantity')
          .eq('user_id', s.user.id)
          .eq('product_id', String(product.id));

        if (variantStr) {
          query = query.eq('variant', variantStr);
        } else {
          query = query.is('variant', null);
        }

        var existing = await query.single();

        if (existing.data) {
          await window.supabaseClient
            .from('cart_items')
            .update({
              quantity:    existing.data.quantity + qty,
              price:       priceNum,
              total_price: priceNum * (existing.data.quantity + qty)
            })
            .eq('id', existing.data.id);
        } else {
          var r = await window.supabaseClient.from('cart_items').insert({
            user_id:      s.user.id,
            product_id:   String(product.id),
            product_name: product.title,
            quantity:     qty,
            price:        priceNum,
            total_price:  priceNum * qty,
            image_url:    thumb,
            variant:      variantStr
          });
          if (r.error) throw r.error;
        }

        showToast('Adicionado ao carrinho!', 'success');

        btn.innerHTML = '✅ No carrinho — <span style="text-decoration:underline;">Ver carrinho</span>';
        btn.disabled = false;
        btn.classList.remove('bg-freo-orange');
        btn.classList.add('bg-green-600', 'text-white');

        btn.onclick = function(e) {
          e.preventDefault();
          window.location.href = '/dashboard.html#cart-section';
        };

        setTimeout(function() {
          btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg> Adicionar ao Carrinho';
          btn.classList.remove('bg-green-600', 'text-white');
          btn.classList.add('bg-freo-orange');
          btn.disabled = false;
          btn.onclick = addToCart;
        }, 4000);

      } catch(err) {
        console.error('Erro ao adicionar:', err);
        showToast('Erro ao adicionar ao carrinho.', 'error');
        btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg> Adicionar ao Carrinho';
        btn.disabled = false;
      }
    }

    // ── Init: busca produto pelo ID na URL ──────────────────────────────────
    async function init() {
      var params = new URLSearchParams(window.location.search);
      var id = params.get('id');

      if (!id) {
        document.getElementById('page-loading').classList.add('hidden');
        document.getElementById('page-notfound').classList.remove('hidden');
        document.getElementById('page-notfound').classList.add('flex');
        return;
      }

      try {
        var result = await window.supabaseClient
          .from('products')
          .select('*')
          .eq('id', id)
          .eq('is_active', true)
          .single();

        if (result.error || !result.data) {
          document.getElementById('page-loading').classList.add('hidden');
          document.getElementById('page-notfound').classList.remove('hidden');
          document.getElementById('page-notfound').classList.add('flex');
          return;
        }

        renderProduct(result.data);

        // Detecta se veio de um redirecionamento pós-login
        var autoAdd = params.get('autoAddToCart');
        if (autoAdd === '1') {
          var pendingRaw = sessionStorage.getItem('pendingCart');
          if (pendingRaw) {
            try {
              var pending = JSON.parse(pendingRaw);

              // Só executa se for o mesmo produto
              if (String(pending.productId) === String(id)) {
                sessionStorage.removeItem('pendingCart'); // limpa antes de adicionar

                // Restaura quantidade
                qty = pending.quantity || 1;
                document.getElementById('qty-display').innerText = qty;

                // Restaura variantes selecionadas
                if (pending.variants && Object.keys(pending.variants).length > 0) {
                  selectedVariants = pending.variants;

                  // Marca visualmente os botões de variante como ativos
                  setTimeout(function() {
                    Object.keys(selectedVariants).forEach(function(vi) {
                      var sel = selectedVariants[vi];
                      var btns = document.querySelectorAll('.variant-btn[data-variant-index="' + vi + '"]');
                      btns.forEach(function(btn) {
                        if (btn.getAttribute('data-option-name') === sel.optionName) {
                          btn.classList.add('active');
                        }
                      });
                    });
                    updatePriceDisplay();
                  }, 100);
                }

                // Aguarda um momento e adiciona ao carrinho automaticamente
                setTimeout(function() {
                  addToCart();
                }, 600);
              } else {
                // Produto diferente, limpa o pendente
                sessionStorage.removeItem('pendingCart');
              }
            } catch(e) {
              sessionStorage.removeItem('pendingCart');
            }
          }
        }

      } catch(err) {
        console.error('Erro ao carregar produto:', err);
        document.getElementById('page-loading').classList.add('hidden');
        document.getElementById('page-notfound').classList.remove('hidden');
        document.getElementById('page-notfound').classList.add('flex');
      }
    }

    document.addEventListener('DOMContentLoaded', init);

    window.addEventListener('auth-data-loaded', function(e) {
      currentUser = e.detail.user;
    });

    // ══════════════════════════════════════════════════════════════
    //  SISTEMA DE AVALIAÇÕES
    // ══════════════════════════════════════════════════════════════

    var allReviews     = [];
    var reviewPage     = 1;
    var reviewsPerPage = 5;
    var selectedRating = 5;
    var selectedFiles  = [];
    var reviewProductId = null;

    // ── Renderiza estrelas (0–5, suporta .5) ────────────────────
    function starsHTML(rating, size) {
      size = size || 16;
      var full = Math.floor(rating);
      var half = (rating - full) >= 0.5 ? 1 : 0;
      var empty = 5 - full - half;
      var html = '';
      var svgOpen = '<svg class="star-svg filled" style="width:' + size + 'px;height:' + size + 'px" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
      var svgEmpty = '<svg class="star-svg empty" style="width:' + size + 'px;height:' + size + 'px;color:rgba(221,175,52,0.2)" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
      for (var i = 0; i < full;  i++) html += svgOpen;
      if (half)                        html += svgOpen; // usa preenchida para meia-estrela visualmente próximo
      for (var j = 0; j < empty; j++) html += svgEmpty;
      return html;
    }

    // ── Barras de distribuição ───────────────────────────────────
    function renderRatingBars(reviews) {
      var counts = {5:0,4:0,3:0,2:0,1:0};
      reviews.forEach(function(r) { var k = Math.round(r.rating); counts[k] = (counts[k]||0)+1; });
      var total = reviews.length || 1;
      var html = '';
      for (var s = 5; s >= 1; s--) {
        var pct = Math.round((counts[s]/total)*100);
        html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">'
          + '<span style="font-family:ui-monospace,monospace;font-size:0.65rem;color:rgba(245,245,245,0.4);width:8px;text-align:right">' + s + '</span>'
          + '<svg style="width:11px;height:11px;color:#DDAF34;flex-shrink:0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
          + '<div style="flex:1;height:5px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden">'
          + '<div style="height:100%;width:' + pct + '%;background:#DDAF34;border-radius:2px;transition:width 0.4s"></div>'
          + '</div>'
          + '<span style="font-family:ui-monospace,monospace;font-size:0.65rem;color:rgba(245,245,245,0.3);width:26px">' + pct + '%</span>'
          + '</div>';
      }
      document.getElementById('rating-bars').innerHTML = html;
    }

    // ── Formata data ─────────────────────────────────────────────
    function fmtDate(iso) {
      if (!iso) return '';
      var d = new Date(iso);
      return d.toLocaleDateString('pt-BR', { day:'2-digit', month:'short', year:'numeric' });
    }

    // ── Renderiza um card ────────────────────────────────────────
    function reviewCardHTML(r) {
      var mediaHTML = '';
      if (r.media_urls && r.media_urls.length > 0) {
        mediaHTML = '<div class="review-media-grid">';
        r.media_urls.forEach(function(url) {
          var isVideo = /\.(mp4|webm|mov)(\?|$)/i.test(url);
          if (isVideo) {
            mediaHTML += '<div class="review-video-thumb" onclick="openLightbox(\'' + url + '\',\'video\')">'
              + '<svg style="width:22px;height:22px;color:#DDAF34" fill="currentColor" viewBox="0 0 20 20"><path d="M8 5v10l8-5-8-5z"/></svg>'
              + '</div>';
          } else {
            mediaHTML += '<img class="review-media-thumb" src="' + url + '" alt="foto da avaliação" loading="lazy" onclick="openLightbox(\'' + url + '\',\'image\')">';
          }
        });
        mediaHTML += '</div>';
      }

      var verifiedLabel = r.is_artificial
        ? '<span class="verified-badge"><svg style="width:9px;height:9px" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Compra verificada</span>'
        : '<span class="verified-badge"><svg style="width:9px;height:9px" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Compra verificada</span>';

      var avatarSrc = r.reviewer_avatar
        ? r.reviewer_avatar
        : 'https://api.dicebear.com/7.x/thumbs/svg?seed=' + encodeURIComponent(r.reviewer_name || 'user') + '&backgroundColor=333333';

      return '<div class="review-card">'
        + '<div style="display:flex;align-items:flex-start;gap:12px">'
        + '<img class="review-avatar" src="' + avatarSrc + '" alt="' + (r.reviewer_name||'') + '" onerror="this.src=\'https://api.dicebear.com/7.x/thumbs/svg?seed=user&backgroundColor=333333\'">'
        + '<div style="flex:1;min-width:0">'
        + '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">'
        + '<span class="review-name">' + (r.reviewer_name || 'Anônimo') + '</span>'
        + verifiedLabel
        + '</div>'
        + '<div style="display:flex;align-items:center;gap:8px;margin-top:3px;flex-wrap:wrap">'
        + '<div class="stars-row">' + starsHTML(r.rating, 14) + '</div>'
        + '<span class="review-date">' + fmtDate(r.created_at) + '</span>'
        + '</div>'
        + '</div>'
        + '</div>'
        + '<p class="review-text">' + (r.comment || '').replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</p>'
        + mediaHTML
        + '</div>';
    }

    // ── Renderiza página de avaliações ───────────────────────────
    function renderReviewsPage() {
      var start  = (reviewPage - 1) * reviewsPerPage;
      var slice  = allReviews.slice(start, start + reviewsPerPage);
      var listEl = document.getElementById('reviews-list');
      if (!listEl) return;

      if (allReviews.length === 0) {
        listEl.innerHTML = '<p style="font-family:ui-monospace,monospace;font-size:0.75rem;color:rgba(245,245,245,0.25);text-align:center;padding:2rem 0;text-transform:uppercase;letter-spacing:0.08em">Nenhuma avaliação ainda. Seja o primeiro!</p>';
      } else {
        listEl.innerHTML = slice.map(reviewCardHTML).join('');
      }

      // Paginação
      var pages = Math.ceil(allReviews.length / reviewsPerPage);
      var pagEl = document.getElementById('reviews-pagination');
      if (pagEl) {
        pagEl.innerHTML = '';
        if (pages > 1) {
          for (var i = 1; i <= pages; i++) {
            var btn = document.createElement('button');
            btn.className = 'page-btn' + (i === reviewPage ? ' active' : '');
            btn.textContent = i;
            btn.setAttribute('data-page', i);
            btn.onclick = (function(pg) { return function() { reviewPage = pg; renderReviewsPage(); document.getElementById('reviews-section').scrollIntoView({behavior:'smooth',block:'start'}); }; })(i);
            pagEl.appendChild(btn);
          }
        }
      }
    }

    // ── Carrega avaliações do Supabase ───────────────────────────
    async function loadReviews(productId) {
      reviewProductId = productId;
      var result = await window.supabaseClient
        .from('product_reviews')
        .select('*')
        .eq('product_id', String(productId))
        .order('created_at', { ascending: false });

      if (result.error) { console.error('Erro ao carregar avaliações:', result.error); return; }

      allReviews = result.data || [];
      reviewPage = 1;

      // Resumo
      var total = allReviews.length;
      var avg   = total > 0 ? (allReviews.reduce(function(s,r){ return s + parseFloat(r.rating||0); }, 0) / total) : 0;
      var avgDisplay = total > 0 ? avg.toFixed(1) : '—';

      var avgNumEl = document.getElementById('rating-avg-num');
      if (avgNumEl) avgNumEl.textContent = avgDisplay;

      var avgStarsEl = document.getElementById('rating-avg-stars');
      if (avgStarsEl) avgStarsEl.innerHTML = total > 0 ? starsHTML(avg, 18) : '';

      var countLabelEl = document.getElementById('rating-count-label');
      if (countLabelEl) countLabelEl.textContent = total + (total === 1 ? ' avaliação' : ' avaliações');

      var totalLabelEl = document.getElementById('review-total-label');
      if (totalLabelEl) totalLabelEl.textContent = total + (total === 1 ? ' avaliação' : ' avaliações');

      renderRatingBars(allReviews);
      renderReviewsPage();

      // Verifica se o usuário pode avaliar (compra entregue)
      renderReviewFormArea(productId);

      // Exibe a seção
      var sec = document.getElementById('reviews-section');
      if (sec) sec.classList.remove('hidden');
    }

    // ── Verifica compra entregue ────────────────────────────────
    async function checkVerifiedBuyer(productId) {
      var sessionRes = await window.supabaseClient.auth.getSession();
      var session = sessionRes.data && sessionRes.data.session;
      if (!session) return { loggedIn: false, verified: false };

      // Checa se já avaliou
      var existingRes = await window.supabaseClient
        .from('product_reviews')
        .select('id')
        .eq('product_id', String(productId))
        .eq('user_id', session.user.id)
        .eq('is_artificial', false)
        .maybeSingle();

      if (existingRes.data) return { loggedIn: true, verified: false, alreadyReviewed: true };

      // Checa pedido entregue
      var ordersRes = await window.supabaseClient
        .from('orders')
        .select('id')
        .eq('user_id', session.user.id)
        .ilike('status', '%entregue%')
        .limit(50);

      if (ordersRes.error || !ordersRes.data || ordersRes.data.length === 0) {
        return { loggedIn: true, verified: false };
      }

      // Verifica se algum pedido contém o produto
      var hasProduct = ordersRes.data.some(function(o) {
        if (!o.items) return false;
        var itemsStr = typeof o.items === 'string' ? o.items : JSON.stringify(o.items);
        return itemsStr.includes(String(productId));
      });

      return { loggedIn: true, verified: hasProduct, user: session.user };
    }

