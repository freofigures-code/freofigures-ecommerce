      background: rgba(221,175,52,0.05);
      padding: 3px 8px;
      border-radius: 2px;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    /* ── Quantidade ── */
    .qty-btn {
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      color: #F5F5F5;
      cursor: pointer;
