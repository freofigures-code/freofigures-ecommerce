  <style>
    * { box-sizing: border-box; }

    /* ── Imagem principal ── */
    #main-img { transition: opacity 0.2s ease; }
    .thumb {
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.15s, transform 0.15s;
      aspect-ratio: 1;
      overflow: hidden;
    }
    .thumb:hover { transform: scale(1.04); }
    .thumb.active { border-color: #DDAF34; }

    /* ── Zoom hover ── */
    .img-zoom-wrap {
      overflow: hidden;
      position: relative;
      cursor: zoom-in;
    }
    .img-zoom-wrap img {
      transition: transform 0.4s ease;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .img-zoom-wrap:hover img { transform: scale(1.08); }

    /* ── Badge de tag ── */
    .tag-pill {
      display: inline-flex;
      align-items: center;
      font-family: ui-monospace, monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 3px 10px;
      border-radius: 2px;
      background: rgba(221,175,52,0.1);
      border: 1px solid rgba(221,175,52,0.25);
      color: #DDAF34;
    }

    /* ── Variante selector ── */
    .variant-btn {
      border: 1px solid rgba(255,255,255,0.12);
      color: rgba(245,245,245,0.6);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      padding: 8px 16px;
      cursor: pointer;
      transition: all 0.15s;
      background: transparent;
      position: relative;
    }
    .variant-btn:hover { border-color: rgba(221,175,52,0.5); color: #F5F5F5; }
    .variant-btn.active { border-color: #DDAF34; color: #DDAF34; background: rgba(221,175,52,0.08); }

    /* Etiqueta de preço na variante */
    .variant-price-tag {
      display: block;
      font-family: ui-monospace, monospace;
      font-size: 0.6rem;
      color: rgba(221,175,52,0.6);
      margin-top: 2px;
      transition: color 0.15s;
    }
    .variant-btn.active .variant-price-tag { color: #DDAF34; }
    .variant-btn:hover .variant-price-tag  { color: rgba(221,175,52,0.9); }

    /* ── Animação de troca de preço ── */
    @keyframes priceFlash {
      0%   { opacity: 0; transform: translateY(-4px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    .price-flash { animation: priceFlash 0.2s ease forwards; }

    /* ── Badge "preço varia por opção" ── */
    .variant-price-notice {
      font-family: ui-monospace, monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: rgba(221,175,52,0.5);
      border: 1px solid rgba(221,175,52,0.15);
      background: rgba(221,175,52,0.05);
      padding: 3px 8px;
      border-radius: 2px;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    /* ── Quantidade ── */
    .qty-btn {
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      color: #F5F5F5;
      cursor: pointer;
      font-size: 18px;
      transition: background 0.15s;
    }
    .qty-btn:hover { background: rgba(221,175,52,0.15); border-color: rgba(221,175,52,0.4); }

    /* ── Toast ── */
    #toast {
      position: fixed;
      bottom: 2rem; right: 2rem;
      z-index: 9999;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.875rem;
      padding: 0.875rem 1.25rem;
      border-radius: 4px;
      transform: translateY(120%);
      transition: transform 0.25s;
      pointer-events: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    #toast.show { transform: translateY(0); }
    #toast.success { background: #1a2e1a; border: 1px solid rgba(34,197,94,0.4); color: #86efac; }
    #toast.error   { background: #2e1a1a; border: 1px solid rgba(239,68,68,0.4); color: #fca5a5; }

    /* ── Skeleton ── */
    @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
    .skeleton {
      background: linear-gradient(90deg,rgba(255,255,255,0.04) 25%,rgba(255,255,255,0.09) 50%,rgba(255,255,255,0.04) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.6s infinite;
      border-radius: 4px;
    }

    /* ── Estoque badge ── */
    .estoque-ok   { color: #4ade80; background: rgba(34,197,94,0.08);  border: 1px solid rgba(34,197,94,0.2); }
    .estoque-low  { color: #fb923c; background: rgba(251,146,60,0.08); border: 1px solid rgba(251,146,60,0.2); }
    .estoque-out  { color: #f87171; background: rgba(239,68,68,0.08);  border: 1px solid rgba(239,68,68,0.2); }

    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: #0A0A0A; }
    ::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
    ::-webkit-scrollbar-thumb:hover { background: #DDAF34; }

    /* ══════════════════════════════════════
       AVALIAÇÕES
    ══════════════════════════════════════ */
    .review-section { margin-top: 3rem; border-top: 1px solid rgba(255,255,255,0.07); padding-top: 2rem; }

    /* Resumo com estrelas */
    .rating-summary { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(221,175,52,0.15); padding: 1.25rem 1.5rem; }
    .rating-big-num { font-family: 'Outfit', sans-serif; font-size: 3rem; font-weight: 900; color: #DDAF34; line-height: 1; }
    .stars-row { display: inline-flex; gap: 2px; }
    .star-svg { width: 18px; height: 18px; }
    .star-svg.filled { color: #DDAF34; }
    .star-svg.empty  { color: rgba(221,175,52,0.2); }
    .star-svg.half   { color: #DDAF34; }
    .rating-count { font-family: ui-monospace,monospace; font-size: 0.7rem; color: rgba(245,245,245,0.4); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 3px; }

    /* Card de avaliação */
    .review-card { background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.07); padding: 1.25rem; margin-bottom: 0.875rem; transition: border-color 0.2s; }
    .review-card:hover { border-color: rgba(221,175,52,0.2); }
    .review-avatar { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; border: 1.5px solid rgba(221,175,52,0.35); flex-shrink: 0; background: #1a1a1a; }
    .review-name { font-family: 'Space Grotesk', sans-serif; font-size: 0.875rem; font-weight: 600; color: #f0f0f0; }
    .review-date { font-family: ui-monospace,monospace; font-size: 0.65rem; color: rgba(245,245,245,0.3); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 1px; }
    .review-text { font-family: 'Space Grotesk', sans-serif; font-size: 0.85rem; color: rgba(245,245,245,0.72); line-height: 1.65; margin-top: 0.625rem; }
    .verified-badge { display: inline-flex; align-items: center; gap: 4px; font-family: ui-monospace,monospace; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em; color: #4ade80; background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); padding: 2px 7px; border-radius: 2px; }

    /* Miniaturas de mídia no card */
    .review-media-grid { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 0.625rem; }
    .review-media-thumb { width: 68px; height: 68px; object-fit: cover; border-radius: 3px; cursor: pointer; border: 1px solid rgba(255,255,255,0.08); transition: opacity 0.15s; }
    .review-media-thumb:hover { opacity: 0.8; }
    .review-video-thumb { width: 68px; height: 68px; border-radius: 3px; cursor: pointer; border: 1px solid rgba(255,255,255,0.08); background: #111; display: flex; align-items: center; justify-content: center; }

    /* Formulário */
    .review-form-wrap { background: rgba(221,175,52,0.04); border: 1px solid rgba(221,175,52,0.18); padding: 1.5rem; margin-top: 1.5rem; }
    .review-form-title { font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #DDAF34; margin-bottom: 1rem; }
    .star-select { display: inline-flex; gap: 4px; margin-bottom: 1rem; }
    .star-select-btn { background: none; border: none; cursor: pointer; padding: 2px; }
    .star-select-btn svg { width: 28px; height: 28px; transition: transform 0.1s; }
    .star-select-btn:hover svg { transform: scale(1.15); }
    .review-input { width: 100%; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); color: #f5f5f5; font-family: 'Space Grotesk', sans-serif; font-size: 0.875rem; padding: 10px 14px; outline: none; resize: vertical; transition: border-color 0.15s; margin-bottom: 0.75rem; }
    .review-input:focus { border-color: rgba(221,175,52,0.5); }
    .review-file-label { display: inline-flex; align-items: center; gap: 7px; font-family: ui-monospace,monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.07em; color: rgba(221,175,52,0.7); border: 1px dashed rgba(221,175,52,0.3); padding: 8px 14px; cursor: pointer; transition: all 0.15s; margin-bottom: 0.75rem; }
    .review-file-label:hover { border-color: rgba(221,175,52,0.6); color: #DDAF34; background: rgba(221,175,52,0.05); }
    .review-previews { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 0.75rem; }
    .review-preview-item { position: relative; width: 64px; height: 64px; }
    .review-preview-item img, .review-preview-item video { width: 64px; height: 64px; object-fit: cover; border-radius: 3px; border: 1px solid rgba(255,255,255,0.1); }
    .review-preview-remove { position: absolute; top: -5px; right: -5px; width: 17px; height: 17px; background: #ef4444; border: none; border-radius: 50%; color: white; font-size: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; }
    .btn-submit-review { background: #DDAF34; color: #0A0A0A; font-family: 'Outfit', sans-serif; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; padding: 12px 28px; font-size: 0.8rem; border: none; cursor: pointer; transition: background 0.15s, transform 0.1s; }
    .btn-submit-review:hover { background: #f0f0f0; }
    .btn-submit-review:active { transform: scale(0.97); }
    .btn-submit-review:disabled { opacity: 0.45; cursor: not-allowed; }

    /* Lock message */
    .review-locked { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); padding: 1rem 1.25rem; font-family: ui-monospace,monospace; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: rgba(245,245,245,0.4); margin-top: 1.5rem; }

    /* Lightbox */
    #review-lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.93); z-index: 99999; display: none; align-items: center; justify-content: center; }
    #review-lightbox.open { display: flex; }
    #review-lightbox img, #review-lightbox video { max-width: 90vw; max-height: 88vh; border-radius: 4px; object-fit: contain; }
    #lightbox-close { position: absolute; top: 16px; right: 20px; background: none; border: none; color: white; font-size: 2rem; cursor: pointer; line-height: 1; opacity: 0.6; }
    #lightbox-close:hover { opacity: 1; }

    /* Paginação */
    .review-pagination { display: flex; gap: 6px; justify-content: center; margin-top: 1.25rem; flex-wrap: wrap; }
    .page-btn { font-family: ui-monospace,monospace; font-size: 0.7rem; padding: 6px 12px; background: transparent; border: 1px solid rgba(255,255,255,0.1); color: rgba(245,245,245,0.5); cursor: pointer; transition: all 0.15s; }
    .page-btn:hover, .page-btn.active { background: rgba(221,175,52,0.12); border-color: rgba(221,175,52,0.4); color: #DDAF34; }

    /* Responsivo mobile */
    @media (max-width: 640px) {
      .rating-summary { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
      .rating-big-num { font-size: 2.2rem; }
    }
  </style>
