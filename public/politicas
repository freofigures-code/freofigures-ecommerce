<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Políticas — Freo Figures</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0e0e0f;
      --surface: #161618;
      --surface2: #1e1e21;
      --border: rgba(255,255,255,0.07);
      --accent: #c8ff3e;
      --accent-dim: rgba(200,255,62,0.07);
      --text: #f0efeb;
      --muted: #888885;
      --muted2: #444441;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      font-size: 15px;
      line-height: 1.75;
    }

    /* ── SIDEBAR NAV ── */
    .layout { display: flex; min-height: 100vh; }

    .sidebar {
      width: 260px;
      min-width: 260px;
      background: var(--surface);
      border-right: 1px solid var(--border);
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      padding: 2rem 0;
    }
    .sidebar-brand {
      padding: 0 1.5rem 1.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.5rem;
    }
    .sidebar-brand .logo {
      font-family: 'DM Serif Display', serif;
      font-size: 18px;
      color: var(--text);
      letter-spacing: 0.02em;
    }
    .sidebar-brand .tagline {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-top: 2px;
    }
    .nav-label {
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted2);
      padding: 0 1.5rem;
      margin-bottom: 6px;
      font-weight: 500;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 1.5rem;
      cursor: pointer;
      transition: all 0.15s;
      border-left: 2px solid transparent;
      color: var(--muted);
      font-size: 13px;
      font-weight: 400;
      user-select: none;
    }
    .nav-item:hover { color: var(--text); background: var(--surface2); }
    .nav-item.active { color: var(--accent); border-left-color: var(--accent); background: var(--accent-dim); }
    .nav-item .nav-icon { font-size: 16px; opacity: 0.7; }
    .nav-item.active .nav-icon { opacity: 1; }
    .nav-num {
      font-size: 10px;
      color: var(--muted2);
      margin-left: auto;
      font-weight: 500;
    }
    .nav-item.active .nav-num { color: var(--accent); opacity: 0.6; }

    .sidebar-footer {
      margin-top: auto;
      padding: 1.25rem 1.5rem 0;
      border-top: 1px solid var(--border);
    }
    .sidebar-footer p { font-size: 11px; color: var(--muted2); line-height: 1.5; }
    .sidebar-footer strong { color: var(--muted); }

    /* ── MAIN CONTENT ── */
    .content { flex: 1; min-width: 0; }

    .page { display: none; }
    .page.active { display: block; }

    .page-header {
      border-bottom: 1px solid var(--border);
      padding: 3rem 3.5rem 2.5rem;
      position: relative;
      overflow: hidden;
    }
    .page-header::after {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 320px; height: 320px;
      background: radial-gradient(circle, rgba(200,255,62,0.05) 0%, transparent 65%);
      pointer-events: none;
    }
    .page-tag {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .page-tag::before { content: ''; display: inline-block; width: 18px; height: 1px; background: var(--accent); }
    .page-header h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(26px, 4vw, 40px);
      font-weight: 400;
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .page-meta { display: flex; flex-wrap: wrap; gap: 1.5rem; }
    .meta-item { font-size: 12px; color: var(--muted); }
    .meta-item strong { color: var(--text); font-weight: 500; display: block; margin-bottom: 2px; }

    .page-body { padding: 2.5rem 3.5rem; max-width: 820px; }

    /* ── SECTIONS ── */
    .section { padding: 2rem 0; border-bottom: 1px solid var(--border); }
    .section:last-child { border-bottom: none; padding-bottom: 0; }
    .sec-num { font-size: 11px; color: var(--accent); letter-spacing: 0.1em; font-weight: 500; margin-bottom: 6px; }
    h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 22px;
      font-weight: 400;
      color: var(--text);
      margin-bottom: 1rem;
    }
    h3 {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 1.5rem 0 0.6rem;
    }
    p { margin-bottom: 0.85rem; color: #b8b7b3; }
    ul, ol { padding-left: 1.3rem; margin-bottom: 0.9rem; color: #b8b7b3; }
    li { margin-bottom: 6px; }
    strong { color: var(--text); font-weight: 500; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── COMPONENTS ── */
    .box {
      background: var(--accent-dim);
      border: 1px solid rgba(200,255,62,0.13);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      margin: 1rem 0;
      font-size: 14px;
      color: #c8c7c3;
      line-height: 1.65;
    }
    .box strong { color: var(--accent); }
    .box.warn {
      background: rgba(239,159,39,0.07);
      border-color: rgba(239,159,39,0.15);
    }
    .box.warn strong { color: #ef9f27; }
    .box.danger {
      background: rgba(226,75,74,0.07);
      border-color: rgba(226,75,74,0.15);
    }
    .box.danger strong { color: #e24b4a; }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      margin: 1rem 0;
    }
    .info-cell { background: var(--surface); padding: 1rem 1.25rem; }
    .info-cell .lbl { font-size: 10px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
    .info-cell .val { font-size: 13px; color: var(--text); word-break: break-word; }

    .data-table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 13px; }
    .data-table th {
      text-align: left; padding: 8px 12px;
      font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--muted); border-bottom: 1px solid var(--border); font-weight: 500;
    }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); color: #b8b7b3; vertical-align: top; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table td:first-child { color: var(--text); }
    .pill {
      display: inline-block;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2px 9px;
      font-size: 11px;
      color: var(--accent);
      white-space: nowrap;
    }

    .rights-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 10px; margin: 1rem 0; }
    .right-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
    }
    .right-card .ricon { font-size: 18px; margin-bottom: 8px; }
    .right-card .rtitle { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
    .right-card .rdesc { font-size: 12px; color: var(--muted); line-height: 1.5; }

    .steps { counter-reset: step; list-style: none; padding: 0; margin: 1rem 0; }
    .steps li {
      counter-increment: step;
      display: flex;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      color: #b8b7b3;
      font-size: 14px;
      align-items: flex-start;
    }
    .steps li:last-child { border-bottom: none; }
    .steps li::before {
      content: counter(step, decimal-leading-zero);
      font-size: 11px;
      font-weight: 500;
      color: var(--accent);
      min-width: 26px;
      padding-top: 3px;
    }

    .contact-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-top: 1rem;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .contact-row { display: flex; align-items: flex-start; gap: 12px; font-size: 13px; }
    .contact-row .clabel { color: var(--muted); min-width: 130px; font-size: 12px; padding-top: 1px; }
    .contact-row .cval { color: var(--text); word-break: break-word; }

    .toc {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      margin: 0 0 2rem;
    }
    .toc-title { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; font-weight: 500; }
    .toc ol { list-style: none; counter-reset: toc; padding: 0; }
    .toc li { counter-increment: toc; display: flex; align-items: baseline; gap: 10px; padding: 5px 0; border-bottom: 1px solid var(--border); }
    .toc li:last-child { border-bottom: none; }
    .toc li::before { content: counter(toc, decimal-leading-zero); font-size: 10px; color: var(--accent); font-weight: 500; min-width: 22px; }
    .toc a { color: var(--muted); font-size: 13px; text-decoration: none; transition: color 0.15s; }
    .toc a:hover { color: var(--text); }

    /* ── MOBILE ── */
    .mobile-nav {
      display: none;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 1rem;
      gap: 6px;
      flex-wrap: wrap;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .mobile-nav-btn {
      font-size: 12px;
      padding: 5px 12px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--muted);
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: all 0.15s;
    }
    .mobile-nav-btn.active { background: var(--accent-dim); color: var(--accent); border-color: rgba(200,255,62,0.2); }
    .mobile-brand { display: none; padding: 1rem 1.25rem; border-bottom: 1px solid var(--border); }
    .mobile-brand .logo { font-family: 'DM Serif Display', serif; font-size: 18px; }
    .mobile-brand .tagline { font-size: 11px; color: var(--muted); }

    @media (max-width: 768px) {
      .sidebar { display: none; }
      .mobile-nav { display: flex; }
      .mobile-brand { display: block; }
      .page-header { padding: 2rem 1.25rem 1.5rem; }
      .page-body { padding: 1.5rem 1.25rem; }
      .rights-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .rights-grid { grid-template-columns: 1fr; }
      .info-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
